# HuggingFace API Token — get yours at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# HuggingFace model to use (default: Mistral 7B Instruct)
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Embedding model (local, downloaded on first run ~90MB)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# PDF output directory (relative to ai-service root)
PDF_OUTPUT_DIR=static/pdfs

# Port for the FastAPI server
PORT=8000
